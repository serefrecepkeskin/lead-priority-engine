# Copy this file to `.env` and fill in real values for your local environment.
# `.env` is gitignored; `.env.example` is the committed template.
# Loader: src/lead_priority/settings.py (pydantic-settings).

# ---- Application ----
APP_ENV=development
LOG_LEVEL=INFO

# ---- API ----
API_HOST=0.0.0.0
API_PORT=8000

# ---- Paths (relative to repo root) ----
DATA_DIR=data
ARTIFACTS_DIR=artifacts

# ---- Model artifacts (filenames inside ARTIFACTS_DIR) ----
LEAD_SCORING_MODEL=lead_scoring_lgbm.joblib
SENTIMENT_MODEL=sentiment_model

# ---- Azure OpenAI (synthetic interaction generation, sentiment via LLM) ----
# `azure_deployment` is the deployment name in your Azure resource, e.g. "gpt-4o-mini".
# `api_version` follows Azure's date format, e.g. "2024-10-21".
# `reasoning_effort` only applies to reasoning models (o1, o3, GPT-5 family): minimal | low | medium | high.
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=
AZURE_OPENAI_MAX_TOKENS=
AZURE_OPENAI_TIMEOUT=
AZURE_OPENAI_REASONING_EFFORT=

# ---- Priority score blending weights ----
# Weighted blend of conversion probability and sentiment intent score.
# Should sum to 1.0; the loader does not enforce this, but it's the convention.
PRIORITY_WEIGHT_CONVERSION=0.6
PRIORITY_WEIGHT_SENTIMENT=0.4

# ---- OpenRouter (Phase 3 sentiment classifier — open-source LLM via API) ----
# Pricing tier (:free model variants) is fine for case-study evaluation.
# Loader: src/lead_priority/settings.py reads open_router_api_key + open_router_base_url.
# Base URL has a default in settings ("https://openrouter.ai/api/v1") and rarely
# needs to change.
OPEN_ROUTER_API_KEY=
