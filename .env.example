# Copy this file to `.env` and fill in real values for your local environment.
# `.env` is gitignored; `.env.example` is the committed template.
# Loader: src/lead_priority/settings.py (pydantic-settings).

# ---- Application ----
APP_ENV=development
LOG_LEVEL=INFO

# ---- API ----
API_HOST=0.0.0.0
API_PORT=8000

# ---- Paths (relative to repo root) ----
DATA_DIR=data
ARTIFACTS_DIR=artifacts

# ---- Model artifacts (filenames inside ARTIFACTS_DIR) ----
LEAD_SCORING_MODEL=lead_scoring_lgbm.joblib
SENTIMENT_MODEL=sentiment_model

# ---- LLM provider for synthetic interaction generation ----
# Leave empty if you are not running the synthetic-data step locally.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ---- Priority score blending weights ----
# Weighted blend of conversion probability and sentiment intent score.
# Should sum to 1.0; the loader does not enforce this, but it's the convention.
PRIORITY_WEIGHT_CONVERSION=0.6
PRIORITY_WEIGHT_SENTIMENT=0.4
